    {
      "@id": "urn:oslo-toolchain:7a7acd6f321eda58696fdb952ef9300318792ab36296cbfca372822c7c40a624",
      "@type": "Class",
      "assignedURI": "http://www.w3.org/ns/sosa/Procedure",
      "vocLabel": [
        {
          "@language": "nl",
          "@value": "Observatieprocedure"
        }
      ],
      "apLabel": [
        {
          "@language": "nl",
          "@value": "Observatieprocedure"
        },
        {
          "@language": "en",
          "@value": "ObservationProcedure"
        }
      ],
      "diagramLabel": [
        {
          "@value": "Observatieprocedure"
        }
      ],
      "apDefinition": [
        {
          "@language": "en",
          "@value": "A workflow,protocol,plan,algorithm,or computational method specifying how to make an Observation."
        },
        {
          "@language": "nl",
          "@value": "Een workflow, protocol, plan, algoritme, of berekeningswijze waarin wordt gespecifieerd hoe een Observatie moet worden uitgevoerd."
        }
      ],
      "apUsageNote": [
        {
          "@language": "nl",
          "@value": "De procedure legt uit welke stappen uitgevoerd moeten worden om een reproduceerbaar resultaat te krijgen. Bijvoorbeeld de correcte plaatsing van een windmeter (op een welbepaalde hoogte boven het grondoppervlak, bijvoorbeeld 10m voor meteorologische waarnemingen). De procedures zijn doorgaans bedoeld om bij meer dan één Bemonstering te worden toegepast."
        },
        {
          "@language": "en",
          "@value": "The procedure explains which steps must be performed to obtain a reproducible result. E.g. the correct placement of an anemometer (at a specific height above the ground surface, bijvoorbeeld 10m for meteorological observations). The procedures are generally intended to be applied to more than one Observation."
        }
      ],
      "scope": "https://data.vlaanderen.be/id/concept/scope/External",
      "parent": [
        {
          "@id": "urn:oslo-toolchain:6ff0cbd6073e3a5e37b5515569a2ee7003717398b2c93d90536f49ea861a69af"
        }
      ],
      "status": "https://data.vlaanderen.be/id/concept/StandaardStatus/ErkendeStandaard"
    },
    {
      "@id": "urn:oslo-toolchain:bdbcfad202dcefc193c7946f539cfd8e2b31d2fc6342b44b79a9bee9ca8e79fc",
      "@type": "Class",
      "assignedURI": "http://www.w3.org/ns/sosa/Sensor",
      "vocLabel": [
        {
          "@language": "nl",
          "@value": "Sensor"
        }
      ],
      "apLabel": [
        {
          "@language": "en",
          "@value": "Sensor"
        },
        {
          "@language": "nl",
          "@value": "Sensor"
        }
      ],
      "diagramLabel": [
        {
          "@value": "Sensor"
        }
      ],
      "vocDefinition": [
        {
          "@language": "nl",
          "@value": "Toestel of Agent (inclusief Personen of software) waarmee Observaties gemaakt worden."
        }
      ],
      "apDefinition": [
        {
          "@language": "en",
          "@value": "Device or Agent (including Persons or software) with which Observations are made."
        },
        {
          "@language": "nl",
          "@value": "Toestel of Agent (inclusief Personen of software) waarmee Observaties gemaakt worden."
        }
      ],
      "vocUsageNote": [
        {
          "@language": "nl",
          "@value": "Sensoren genereren een resultaat op basis van een Stimulus, het is te zeggen een verandering in de omgeving, of op basis van resultaten van andere Observaties. Ze worden typisch gehost door een Platform. Voorbeelden zijn snelheidsmeters, gyroscopen, barometers, magnetometers gemonteerd op een smart phone. Ook bijvoorbeeld het menselijk oog kan beschouwd worden als een sensor."
        }
      ],
      "apUsageNote": [
        {
          "@language": "en",
          "@value": "Sensors generate a result based on a stimulus, i.e. a change in the environment, or based on results from other Observations. They are typically hosted by a Platform. Examples are speedometers, gyroscopes, barometers, magnetometers mounted on a smart phone. The human eye, for example, can also be regarded as a Sensor."
        },
        {
          "@language": "nl",
          "@value": "Sensoren genereren een resultaat op basis van een Stimulus, het is te zeggen een verandering in de omgeving, of op basis van resultaten van andere Observaties. Ze worden typisch gehost door een Platform. Voorbeelden zijn snelheidsmeters, gyroscopen, barometers, magnetometers gemonteerd op een smart phone. Ook bijvoorbeeld het menselijk oog kan beschouwd worden als een sensor."
        }
      ],
      "scope": "https://data.vlaanderen.be/id/concept/scope/External",
      "parent": [
        {
          "@id": "urn:oslo-toolchain:ee4ffe120f524e76e78d98f158066f1cc2f43888777b46ca02d2c9cc7794e975"
        }
      ],
      "status": "https://data.vlaanderen.be/id/concept/StandaardStatus/ErkendeStandaard"
    },
    {
      "@id": "urn:oslo-toolchain:fec6473d419e4e2ff65da745a6f7d77fb370e8cb79c48e3a2b4dd005e7421228",
      "@type": "Class",
      "assignedURI": "http://www.w3.org/ns/sosa/ObservationCollection",
      "vocLabel": [
        {
          "@language": "nl",
          "@value": "Observatieverzameling"
