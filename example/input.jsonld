        }
      ],
      "diagramLabel": [
        {
          "@value": "Nutsvoorzieningnetwerk"
        }
      ],
      "vocDefinition": [
        {
          "@language": "nl",
          "@value": "Verzameling van netwerkelementen van één type nutsvoorziening."
        },
        {
          "@language": "en",
          "@value": "Collection of network elements of one type of utility service."
        }
      ],
      "apDefinition": [
        {
          "@language": "nl",
          "@value": "Verzameling van netwerkelementen van één type nutsvoorziening."
        }
      ],
      "vocUsageNote": [
        {
          "@language": "nl",
          "@value": "Bvb een electriciteitsnet, een rioleringsnet, een gasnet. De netwerkelementen waarvan sprake zijn bvb de elementen van het netwerk van een aanbiedervan internet: optische kabels aankomend in kasten op straat via multiplexers verbonden met koperkabels naar de woningen in die straat."
        },
        {
          "@language": "en",
          "@value": "For example, an electricity network, a sewerage network, a gas network. The network elements in question are, for example, the elements of the network of an internet provider: optical cables arriving in cabinets on the street via multiplexers connected to copper cables to the homes in that street."
        }
      ],
      "apUsageNote": [
        {
          "@language": "nl",
          "@value": "Bvb een electriciteitsnet, een rioleringsnet, een gasnet. De netwerkelementen waarvan sprake zijn bvb de elementen van het netwerk van een aanbiedervan internet: optische kabels aankomend in kasten op straat via multiplexers verbonden met koperkabels naar de woningen in die straat."
        }
      ],
      "scope": "https://data.vlaanderen.be/id/concept/scope/External",
      "status": "https://data.vlaanderen.be/id/concept/StandaardStatus/ErkendeStandaard"
    },
