      ],
      "apDefinition": [
        {
          "@language": "nl",
          "@value": "Het vaststellen van de waarde van een bepaald kenmerk van een Object op een bepaald tijdstip of tussen twee tijdstippen."
        }
      ],
      "apUsageNote": [
        {
          "@language": "nl",
          "@value": "Het gaat om schattingen van de waarde, met andere woorden op de waarde zit een zekere foutmarge. Voorbeelden zijn temperatuur, klasse, kleur. Dit is verschillend van waarden die zijn toegekend en dus geen schattingen zijn zoals naam of prijs."
        }
      ],
      "scope": "https://data.vlaanderen.be/id/concept/scope/External",
