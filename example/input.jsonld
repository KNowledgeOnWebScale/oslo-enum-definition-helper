      "vocUsageNote": [
        {
          "@language": "nl",
          "@value": "Kan als Nutsvoorzieningknoop op zichzelf staan maar is dikwijls gemonteerd op een drager (de Nutsvoorzieningknoopcontainter). Bvb inspectieluik,hydrant,splitter,meter,pomp etc."
        },
        {
          "@language": "en",
          "@value": "Can stand alone as a Utility Node,but is often mounted on a carrier (the Utility Node Container). For example an inspection hatch,a hydrant,a splitter,a meter,a pump etc."
        }
      ],
