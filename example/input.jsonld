          "@value": "Belgisch Adres"
        }
      ],
      "diagramLabel": [
        {
          "@value": "Adres"
        }
      ],
      "vocDefinition": [
        {
          "@language": "nl",
          "@value": "Informatie die toelaat om in België op een gestructureerde en unieke manier te verwijzen naar een \"gebouweenheid\", \"gebouw\", een “ligplaats”, een “standplaats” of een “perceel” op basis van de naam van de “gemeente, de “straatnaam” en het “huisnummer” eventueel aangevuld met een “busnummer” en met een “postcode”."
        }
      ],
      "apDefinition": [
        {
          "@language": "nl",
          "@value": "Informatie die toelaat om op een gestructureerde en unieke manier te verwijzen naar een gebouweenheid,een ligplaats, een standplaats of een perceel op basis van een gemeentenaam, een straatnaam, een huisnummer en eventueel een busnummer en een postcode."
        }
      ],
      "apUsageNote": [
        {
          "@language": "nl",
          "@value": "De definitie heeft betrekking op Belgische adressen. Meer info over deze klasse in het applicatieprofiel <a href=\"https://data.vlaanderen.be/doc/applicatieprofiel/adresregister/\">OSLO-Adresregister</a>."
        }
      ],
